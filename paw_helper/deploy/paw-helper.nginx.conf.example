# nginx vhost: helper.example.com -> the local paw-helper service (port 8088).
# Install:
#   sudo cp paw-helper.nginx.conf.example /etc/nginx/sites-available/helper.example.com
#   sudo ln -s /etc/nginx/sites-available/helper.example.com /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#   sudo certbot --nginx -d helper.example.com   # adds the :443 block + redirect
#
# CORS is handled by the app (HELPER_ALLOWED_ORIGINS), so nginx adds no CORS headers.
#
# Re-deploying this file later? It DRIFTS from what is actually live (certbot edits the
# live file in place; hand-tweaks accumulate). Before overwriting the live config:
#   1. Find the served file: `sudo nginx -T | grep -n "server_name helper.example.com"`
#      (it may be a differently-named file in sites-enabled/, not sites-available/).
#   2. `diff` live vs this file - the only differences should be your intended change;
#      if live has extra blocks (TLS, redirects, CORS), reconcile this file to match
#      live FIRST. Never clobber live with a stale copy.
#   3. Back up the live file to /root (NOT into sites-enabled/ - `include sites-enabled/*`
#      loads every file there, so a `.bak` becomes a duplicate `server` block).
#   4. `sudo nginx -t` before `sudo systemctl reload nginx`; restore the backup if it fails.

server {
    listen 80;
    listen [::]:80;
    server_name helper.example.com;

    client_max_body_size 16k;   # small JSON requests only

    location / {
        proxy_pass http://127.0.0.1:8088;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # The first /ask after a restart may load the base model; allow headroom.
        proxy_read_timeout 60s;
    }
}
